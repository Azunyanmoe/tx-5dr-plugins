{
  "name": "frpc-connector",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "node -e \"console.log('no build needed')\""
  },
  "tx5drPlugin": {
    "pluginName": "网页内网穿透-Windows版",
    "title": "网页内网穿透-Windows版",
    "description": "自动下载配置并通过 FRPC 启动网页内网穿透，适用于 Windows。",
    "minHostVersion": "1.0.0",
    "entry": "src/index.js",
    "include": [
      { "from": "src/index.js", "to": "plugin.js" },
      { "from": "frpc.exe", "to": "frpc.exe" },
      { "from": "README.md", "to": "README.md" }
    ]
  }
}