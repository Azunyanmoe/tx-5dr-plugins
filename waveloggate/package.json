{
  "name": "tx5dr-waveloggate",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "description": "Real-time WaveLog integration plugin for TX-5DR",
  "main": "src/index.js",
  "author": "BI7ALG",
  "license": "MIT",
  "scripts": {
    "build": "node -e \"console.log('no build needed')\""
  },
  "tx5drPlugin": {
    "pluginName": "tx5dr-waveloggate",
    "title": "WaveLogGate for TX-5DR",
    "description": "Real-time WaveLog radio frequency and mode synchronization for TX-5DR.",
    "minHostVersion": "1.7.11",
    "author": "BI7ALG",
    "license": "MIT",
    "repository": "https://github.com/BI7ALG/tx5dr-waveloggate-plugin",
    "categories": [
      "logging",
      "integration"
    ],
    "keywords": [
      "wavelog",
      "radio",
      "frequency",
      "mode"
    ],
    "entry": "src/index.js",
    "include": [
      {
        "from": "src/index.js",
        "to": "index.js"
      },
      {
        "from": "src/locales",
        "to": "locales"
      },
      {
        "from": "README.md",
        "to": "README.md"
      }
