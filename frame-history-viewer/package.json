{
  "name": "tx5dr-plugin-frame-history-viewer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "tx5drPlugin": {
    "pluginName": "frame-history-viewer",
    "title": "Frame History Viewer",
    "description": "Browse historical FT8/FT4 decode frames stored in JSONL log files.",
    "minHostVersion": "1.0.0",
    "author": "TX-5DR",
    "license": "GPL-3.0-only",
    "repository": "https://github.com/boybook/tx-5dr-plugins",
    "homepage": "https://tx5dr.com/plugins/frame-history-viewer",
    "categories": [
      "utility",
      "debug",
      "ui"
    ],
    "keywords": [
      "frames",
      "history",
      "decode",
      "ft8",
      "viewer",
      "jsonl"
    ],
    "entry": "dist/index.js",
    "include": [
      {
        "from": "dist/index.js",
        "to": "index.js"
      },
      {
        "from": "dist/locales",
        "to": "locales"
      },
      {
        "from": "ui/viewer.html",
        "to": "ui/viewer.html"
      },
      {
        "from": "ui/viewer.css",
        "to": "ui/viewer.css"
      },
      {
        "from": "ui/viewer.js",
        "to": "ui/viewer.js"
      }
    ]
  },
  "devDependencies": {
    "@tx5dr/plugin-api": "^1.7.8",
    "@types/node": "^22.19.20",
    "typescript": "^5.0.0"
  }
}
